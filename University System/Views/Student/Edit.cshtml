@model University_System.Models.Student
@{
    ViewData["Title"] = "Edit Student";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Edit Student</h1>
        <p class="page-subtitle">Update the profile details for <strong>@Model.Name</strong>.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-controller="Student" asp-action="Details" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye me-1"></i> View Profile
        </a>
        <a asp-controller="Student" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <form asp-controller="Student" asp-action="Edit"
              method="post" enctype="multipart/form-data">

            <input asp-for="Id" type="hidden" />

            <!-- Personal Information -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title">
                        <i class="bi bi-person-badge me-2 text-primary"></i>Personal Information
                    </h5>
                    <span class="ms-auto badge bg-light text-dark">#@Model.Id</span>
                </div>
                <div class="p-4">
                    <div class="row g-3">

                        <div class="col-sm-6">
                            <label class="form-label-styled">SSN</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-shield-lock input-icon"></i>
                                <input asp-for="SSN" class="form-control form-input-styled"
                                       placeholder="e.g. 123-45-6789" required />
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-styled">Full Name</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-person input-icon"></i>
                                <input asp-for="Name" class="form-control form-input-styled"
                                       placeholder="e.g. John Smith" required />
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-styled">Email Address</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-envelope input-icon"></i>
                                <input asp-for="Email" type="email" class="form-control form-input-styled"
                                       placeholder="e.g. john@university.edu" required />
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-styled">Phone Number</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-telephone input-icon"></i>
                                <input asp-for="Phone" class="form-control form-input-styled"
                                       placeholder="e.g. +1 555 000 1234" required />
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-styled">Age</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-calendar2 input-icon"></i>
                                <input asp-for="Age" type="number" min="16" max="100"
                                       class="form-control form-input-styled"
                                       placeholder="e.g. 21" required />
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <label class="form-label-styled">Address</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-geo-alt input-icon"></i>
                                <input asp-for="Address" class="form-control form-input-styled"
                                       placeholder="e.g. 123 Main St, New York" required />
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- Academic Information -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title">
                        <i class="bi bi-building me-2 text-primary"></i>Academic Information
                    </h5>
                </div>
                <div class="p-4">
                    <label class="form-label-styled">Department</label>
                    <div class="input-icon-wrapper">
                        <i class="bi bi-building input-icon"></i>
                        <select asp-for="DepartmentId"
                                class="form-select form-input-styled form-select-styled" required>
                            <option value="">— Select Department —</option>
                            @foreach (var dept in ViewBag.Departments)
                            {
                                <option value="@dept.DepartmentId"
                                        selected="@(dept.DepartmentId == Model.DepartmentId ? "selected" : null)">
                                    @dept.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Profile Image -->
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title">
                        <i class="bi bi-image me-2 text-primary"></i>Profile Image
                    </h5>
                    <span class="ms-auto text-muted small">Optional — leave empty to keep current</span>
                </div>
                <div class="p-4">

                    <!-- Current image preview -->
                    @if (!string.IsNullOrEmpty(Model.Image))
                    {
                        <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3"
                             style="background:var(--body-bg); border:1px solid var(--card-border);">
                            <img src="/images/@Model.Image" class="profile-avatar"
                                 style="width:64px;height:64px;" alt="Current image" />
                            <div>
                                <div class="fw-semibold">Current Profile Image</div>
                                <div class="text-muted small">Upload a new image below to replace it.</div>
                            </div>
                            <span class="ms-auto status-badge status-badge--active">Active</span>
                        </div>
                    }

                    <!-- Upload new image -->
                    <div class="upload-area" id="uploadArea">
                        <input asp-for="ImageFile" type="file" id="imageFile"
                               class="upload-input" accept="image/*" />
                        <div class="upload-placeholder" id="uploadPlaceholder">
                            <i class="bi bi-cloud-arrow-up upload-icon"></i>
                            <p class="upload-text">
                                @(string.IsNullOrEmpty(Model.Image) ? "Click to upload or drag & drop" : "Click to change profile image")
                            </p>
                            <p class="upload-hint">PNG, JPG, GIF up to 5MB</p>
                        </div>
                        <div class="upload-preview d-none" id="uploadPreview">
                            <img id="previewImg" src="#" alt="Preview" class="upload-preview-img" />
                            <button type="button" class="upload-remove-btn" id="removeImage"
                                    title="Remove">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="d-flex gap-3 justify-content-end">
                <a asp-controller="Student" asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-floppy me-1"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
<script>
    const fileInput   = document.getElementById('imageFile');
    const placeholder = document.getElementById('uploadPlaceholder');
    const preview     = document.getElementById('uploadPreview');
    const previewImg  = document.getElementById('previewImg');
    const removeBtn   = document.getElementById('removeImage');
    const uploadArea  = document.getElementById('uploadArea');

    uploadArea.addEventListener('click', function (e) {
        if (e.target !== removeBtn && !removeBtn.contains(e.target)) fileInput.click();
    });

    fileInput.addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const reader = new FileReader();
            reader.onload = e => {
                previewImg.src = e.target.result;
                placeholder.classList.add('d-none');
                preview.classList.remove('d-none');
            };
            reader.readAsDataURL(this.files[0]);
        }
    });

    removeBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        fileInput.value = '';
        previewImg.src  = '#';
        preview.classList.add('d-none');
        placeholder.classList.remove('d-none');
    });

    uploadArea.addEventListener('dragover',  e => { e.preventDefault(); uploadArea.classList.add('upload-area--drag'); });
    uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('upload-area--drag'));
    uploadArea.addEventListener('drop', function (e) {
        e.preventDefault();
        uploadArea.classList.remove('upload-area--drag');
        const file = e.dataTransfer.files[0];
        if (file && file.type.startsWith('image/')) {
            const dt = new DataTransfer();
            dt.items.add(file);
            fileInput.files = dt.files;
            fileInput.dispatchEvent(new Event('change'));
        }
    });
</script>
}
