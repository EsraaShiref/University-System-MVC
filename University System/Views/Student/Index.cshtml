@model List<University_System.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Students</h1>
        <p class="page-subtitle">Manage and view all enrolled students.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-funnel me-1"></i> Filter
        </button>
        <a class="btn btn-primary btn-sm" asp-action="Add">
            <i class="bi bi-plus-lg me-1"></i> Add Student
        </a>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
        <div class="mini-stat-card">
            <i class="bi bi-people-fill mini-stat-icon text-primary"></i>
            <div>
                <div class="mini-stat-value">@Model.Count</div>
                <div class="mini-stat-label">Total Students</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="mini-stat-card">
            <i class="bi bi-person-check-fill mini-stat-icon text-success"></i>
            <div>
                <div class="mini-stat-value">@Model.Count</div>
                <div class="mini-stat-label">Active</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="mini-stat-card">
            <i class="bi bi-person-x-fill mini-stat-icon text-danger"></i>
            <div>
                <div class="mini-stat-value">0</div>
                <div class="mini-stat-label">Inactive</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="mini-stat-card">
            <i class="bi bi-building mini-stat-icon text-warning"></i>
            <div>
                <div class="mini-stat-value">@Model.Select(s => s.DepartmentId).Distinct().Count()</div>
                <div class="mini-stat-label">Departments</div>
            </div>
        </div>
    </div>
</div>

<!-- Students Table Card -->
<div class="content-card">
    <div class="content-card-header">
        <h5 class="content-card-title">
            <i class="bi bi-table me-2 text-primary"></i>All Students
        </h5>
        <div class="ms-auto d-flex gap-2 align-items-center">
            <div class="search-input-wrapper">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="form-control form-control-sm search-input"
                       id="studentSearch" placeholder="Search students..." />
            </div>
            <button class="btn btn-sm btn-outline-secondary" title="Export">
                <i class="bi bi-download"></i>
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table uni-table mb-0" id="studentsTable">
            <thead>
                <tr>
                    @* <th>#</th> *@
                    <th>Student</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Department</th>
                    <th>Courses</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        @* <td class="text-muted small fw-semibold">#@student.Id</td> *@
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(student.Image))
                                {
                                    <img src="@Url.Content("~/images/" + student.Image)"
                                         class="student-avatar" alt="@student.Name" />
                                }
                                else
                                {
                                    <div class="student-avatar-placeholder">
                                        @(student.Name?.Substring(0, 1).ToUpper())
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold">@student.Name</div>
                                    <div class="text-muted small">@student.Email</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted">@student.Email</td>
                        <td class="text-muted">@student.Phone</td>
                        <td>
                            @if (student.Department != null)
                            {
                                <span class="dept-badge">
                                    <i class="bi bi-building me-1"></i>@student.Department.Name
                                </span>
                            }
                            else { <span class="text-muted small">—</span> }
                        </td>
                        <td>
                            @{ var courseCount = student.StudentCourses?.Count ?? 0; }
                            @if (courseCount > 0)
                            {
                                <span class="courses-badge">
                                    <i class="bi bi-journal-bookmark me-1"></i>
                                    @courseCount Course@(courseCount > 1 ? "s" : "")
                                </span>
                            }
                            else { <span class="text-muted small">No courses</span> }
                        </td>
                        <td><span class="status-badge status-badge--active">Active</span></td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="Student" asp-action="Details"
                                   asp-route-id="@student.Id"
                                   class="btn btn-sm btn-icon" title="View Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-controller="Student" asp-action="Edit"
                                        asp-route-id="@student.Id"
                                    class="btn btn-sm btn-icon btn-icon--edit" title="Edit" disabled>
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Student" asp-action="Delete"
                                   asp-route-id="@student.Id"
                                    class="btn btn-sm btn-icon btn-icon--delete" title="Delete"
                                    onclick="return confirm('Delete @student.Name?')"
                                >
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="content-card-footer">
        <span class="text-muted small">Showing <strong>@Model.Count</strong> students</span>
        <div class="ms-auto d-flex gap-1">
            <button class="btn btn-sm btn-outline-secondary disabled">Previous</button>
            <button class="btn btn-sm btn-primary">1</button>
            <button class="btn btn-sm btn-outline-secondary disabled">Next</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('studentSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#studentsTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>
}
