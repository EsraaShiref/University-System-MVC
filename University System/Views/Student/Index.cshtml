@model List<University_System.Models.Student>
@{
    ViewData["Title"] = "Students List";
}

<div class="card">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Department</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>
                            @if (student.Image != null)
                            {
                                <img src="@student.Image" width="45" height="45"
                                     style="border-radius:50%; object-fit:cover;" />
                            }
                            else
                            {
                                <div style="width:45px;height:45px;border-radius:50%;
                                    background:#4e73df;display:flex;
                                    align-items:center;justify-content:center;
                                    color:white;font-weight:bold;">
                                    @(student.Name?.Substring(0, 1).ToUpper())
                                </div>
                            }
                        </td>
                        <td class="fw-semibold">@student.Name</td>
                        <td class="text-muted">@student.Email</td>
                        <td>@student.Phone</td>
                        <td>
                            <a asp-controller="Student" asp-action="Details"
                               asp-route-id="@student.Id"
                               class="btn btn-sm btn-info text-white me-1">Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>