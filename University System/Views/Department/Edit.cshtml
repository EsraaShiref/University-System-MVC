@model University_System.Models.Department
@{
    ViewData["Title"] = "Edit Department";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Edit Department</h1>
        <p class="page-subtitle">Update the details for <strong>@Model.Name</strong>.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-action="GetByName" asp-route-name="@Model.Name"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-eye me-1"></i> View Details
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="DepartmentId" />

            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title">
                        <i class="bi bi-pencil me-2 text-primary"></i>Edit Department Info
                    </h5>
                    <span class="ms-auto badge bg-light text-dark">#@Model.DepartmentId</span>
                </div>
                <div class="p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label-styled">Department Name</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-building input-icon"></i>
                                <input asp-for="Name" class="form-control form-input-styled" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-styled">Location</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-geo-alt input-icon"></i>
                                <input asp-for="Location" class="form-control form-input-styled" />
                            </div>
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-styled">Phone Number</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-telephone input-icon"></i>
                                <input asp-for="PhoneNumber" class="form-control form-input-styled" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-floppy me-1"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
