@model University_System.Models.Department
@{
    ViewData["Title"] = Model.Name + " — Details";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-subtitle">Department overview — students, instructors and info.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.DepartmentId" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- LEFT: Info Card -->
    <div class="col-lg-4">
        <div class="content-card text-center py-4 mb-4">
            <div class="dept-profile-icon mx-auto mb-3">
                <i class="bi bi-building-fill"></i>
            </div>
            <h4 class="fw-bold mb-1">@Model.Name</h4>
            <p class="text-muted mb-3">Dept. ID: <span class="badge bg-light text-dark">#@Model.DepartmentId</span></p>

            <div class="profile-divider my-3"></div>

            <div class="profile-meta">
                <div class="profile-meta-item">
                    <i class="bi bi-geo-alt text-primary"></i>
                    <span class="small text-muted">@Model.Location</span>
                </div>
                <div class="profile-meta-item">
                    <i class="bi bi-telephone text-primary"></i>
                    <span class="small text-muted">@Model.PhoneNumber</span>
                </div>
            </div>

            <div class="profile-divider my-3"></div>

            <div class="d-flex justify-content-around px-3">
                <div class="text-center">
                    <div class="fw-bold fs-4 text-primary">@Model.Students.Count</div>
                    <div class="text-muted" style="font-size:11px;">Students</div>
                </div>
                <div class="text-center">
                    <div class="fw-bold fs-4 text-violet">@Model.Instructors.Count</div>
                    <div class="text-muted" style="font-size:11px;">Instructors</div>
                </div>
            </div>
        </div>

        <!-- Dept Info Card -->
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-info-circle me-2 text-primary"></i>Department Info
                </h5>
            </div>
            <div class="row g-0">
                <div class="col-12">
                    <div class="info-field">
                        <label class="info-label">Name</label>
                        <div class="info-value">@Model.Name</div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="info-field">
                        <label class="info-label">Location</label>
                        <div class="info-value">
                            <i class="bi bi-geo-alt text-muted me-1"></i>@Model.Location
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="info-field" style="border-bottom:none;">
                        <label class="info-label">Phone Number</label>
                        <div class="info-value">@Model.PhoneNumber</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Students + Instructors -->
    <div class="col-lg-8 d-flex flex-column gap-4">

        <!-- Students in this department -->
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-people-fill me-2 text-primary"></i>Students
                </h5>
                <span class="ms-auto courses-badge">
                    <i class="bi bi-people me-1"></i>@Model.Students.Count
                </span>
            </div>

            @if (Model.Students.Any())
            {
                <div class="table-responsive">
                    <table class="table uni-table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Student</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int sRow = 1; }
                            @foreach (var s in Model.Students)
                            {
                                <tr>
                                    <td class="text-muted small">@(sRow++)</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(s.Image))
                                            {
                                                <img src="@Url.Content("~/images/" + s.Image)"
                                                     class="student-avatar" alt="@s.Name" />
                                            }
                                            else
                                            {
                                                <div class="student-avatar-placeholder">
                                                    @(s.Name?.Substring(0, 1).ToUpper())
                                                </div>
                                            }
                                            <span class="fw-semibold">@s.Name</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">@s.Email</td>
                                    <td class="text-muted">@s.Phone</td>
                                    <td>
                                        <a asp-controller="Student" asp-action="Details"
                                           asp-route-id="@s.Id" class="btn btn-sm btn-icon" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-courses-state">
                    <i class="bi bi-person-x empty-courses-icon"></i>
                    <p class="empty-courses-text">No students in this department yet.</p>
                </div>
            }
        </div>

        <!-- Instructors in this department -->
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-person-workspace me-2 text-primary"></i>Instructors
                </h5>
                <span class="ms-auto dept-badge">
                    <i class="bi bi-person-workspace me-1"></i>@Model.Instructors.Count
                </span>
            </div>

            @if (Model.Instructors.Any())
            {
                <div class="table-responsive">
                    <table class="table uni-table mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Degree</th>
                                <th>Salary</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int iRow = 1; }
                            @foreach (var ins in Model.Instructors)
                            {
                                <tr>
                                    <td class="text-muted small">@(iRow++)</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="student-avatar-placeholder"
                                                 style="background:var(--violet);font-size:13px;width:34px;height:34px;">
                                                @(ins.Name?.Substring(0, 1).ToUpper())
                                            </div>
                                            <span class="fw-semibold">@ins.Name</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">@ins.Email</td>
                                    <td>
                                        <span class="dept-badge">@ins.Degree</span>
                                    </td>
                                    <td class="text-muted">$@ins.Salary.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-courses-state">
                    <i class="bi bi-person-x empty-courses-icon"></i>
                    <p class="empty-courses-text">No instructors assigned to this department yet.</p>
                </div>
            }
        </div>

    </div>
</div>
