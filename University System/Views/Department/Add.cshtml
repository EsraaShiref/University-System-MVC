@model University_System.Models.Department
@{
    ViewData["Title"] = "Add Department";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Add Department</h1>
        <p class="page-subtitle">Create a new department in the university system.</p>
    </div>
    <div class="ms-auto">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <form asp-action="Add">
            <div class="content-card mb-4">
                <div class="content-card-header">
                    <h5 class="content-card-title">
                        <i class="bi bi-building me-2 text-primary"></i>Department Information
                    </h5>
                </div>
                <div class="p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label-styled">Department Name</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-building input-icon"></i>
                                <input asp-for="Name" class="form-control form-input-styled"
                                       placeholder="e.g. Computer Science" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-styled">Location</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-geo-alt input-icon"></i>
                                <input asp-for="Location" class="form-control form-input-styled"
                                       placeholder="e.g. Building A, Floor 2" />
                            </div>
                            <span asp-validation-for="Location" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label class="form-label-styled">Phone Number</label>
                            <div class="input-icon-wrapper">
                                <i class="bi bi-telephone input-icon"></i>
                                <input asp-for="PhoneNumber" class="form-control form-input-styled"
                                       placeholder="e.g. +1 555 000 1234" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg me-1"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-floppy me-1"></i> Save Department
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
