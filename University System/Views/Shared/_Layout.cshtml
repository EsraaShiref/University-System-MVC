<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== SIDEBAR ===== -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <div class="logo-icon"><i class="bi bi-mortarboard-fill"></i></div>
                <div class="logo-text">
                    <span class="logo-title">UniSystem</span>
                    <span class="logo-subtitle">Admin Panel</span>
                </div>
            </div>
            <button class="sidebar-toggle-btn d-lg-none" id="sidebarClose">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="sidebar-divider"></div>

        <nav class="sidebar-nav">
            <p class="sidebar-label">MAIN MENU</p>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill nav-icon"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
            </ul>

            <p class="sidebar-label mt-4">ACADEMIC</p>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Student" ? "active" : "")"
                           asp-controller="Student" asp-action="Index">
                        <i class="bi bi-people-fill nav-icon"></i>
                        <span>Students</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Department" ? "active" : "")"
                           asp-controller="Department" asp-action="Index">
                        <i class="bi bi-building nav-icon"></i>
                        <span>Departments</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Course" ? "active" : "")"
                           asp-controller="Course" asp-action="Index">
                        <i class="bi bi-journal-bookmark-fill nav-icon"></i>
                        <span>Courses</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Instructor" ? "active" : "")"
                           asp-controller="Instructor" asp-action="Index">
                        <i class="bi bi-person-workspace nav-icon"></i>
                        <span>Instructors</span>
                    </a>
                </li>
            </ul>

            <p class="sidebar-label mt-4">SYSTEM</p>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link disabled" href="#">
                        <i class="bi bi-bar-chart-fill nav-icon"></i>
                        <span>Reports</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link disabled" href="#">
                        <i class="bi bi-gear-fill nav-icon"></i>
                        <span>Settings</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">A</div>
                <div class="user-info">
                    <span class="user-name">Admin</span>
                    <span class="user-role">Administrator</span>
                </div>
                <i class="bi bi-three-dots-vertical ms-auto text-muted"></i>
            </div>
        </div>
    </aside>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ===== MAIN WRAPPER ===== -->
    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <button class="menu-toggle-btn" id="menuToggle"><i class="bi bi-list"></i></button>
                <nav aria-label="breadcrumb" class="ms-3 d-none d-md-flex align-items-center">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Home</a>
                        </li>
                        @if (ViewData["Title"]?.ToString() is string t && t != "Dashboard")
                        {
                            <li class="breadcrumb-item active">@t</li>
                        }
                    </ol>
                </nav>
            </div>
            <div class="topbar-right">
                <button class="topbar-btn" title="Search"><i class="bi bi-search"></i></button>
                <button class="topbar-btn position-relative" title="Notifications">
                    <i class="bi bi-bell"></i>
                    <span class="notif-dot"></span>
                </button>
                <div class="topbar-divider"></div>
                <div class="topbar-user">
                    <div class="topbar-avatar">A</div>
                    <span class="d-none d-md-inline fw-semibold">Admin</span>
                    <i class="bi bi-chevron-down ms-1 small text-muted"></i>
                </div>
            </div>
        </header>

        <main class="page-content">@RenderBody()</main>

        <footer class="page-footer">
            <span>&copy; @DateTime.Now.Year University System</span>
            <span class="ms-auto">
                <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy</a>
            </span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
