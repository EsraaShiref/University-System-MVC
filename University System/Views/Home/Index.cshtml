@model List<University_System.Models.Student>
@{
    ViewData["Title"] = "University System";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back, Admin! Here's what's happening today.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-download me-1"></i> Export
        </button>
        <a asp-controller="Student" asp-action="Index" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Student
        </a>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--blue">
            <div class="stat-icon">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Total Students</p>
                <h3 class="stat-value">5</h3>
                <span class="stat-badge stat-badge--up">
                    <i class="bi bi-arrow-up-short"></i> 12% this month
                </span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--teal">
            <div class="stat-icon">
                <i class="bi bi-journal-bookmark-fill"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Active Courses</p>
                <h3 class="stat-value">24</h3>
                <span class="stat-badge stat-badge--up">
                    <i class="bi bi-arrow-up-short"></i> 4 new this term
                </span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--violet">
            <div class="stat-icon">
                <i class="bi bi-building"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Departments</p>
                <h3 class="stat-value">8</h3>
                <span class="stat-badge stat-badge--neutral">
                    <i class="bi bi-dash"></i> No change
                </span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--orange">
            <div class="stat-icon">
                <i class="bi bi-person-check-fill"></i>
            </div>
            <div class="stat-body">
                <p class="stat-label">Enrolled Today</p>
                <h3 class="stat-value">3</h3>
                <span class="stat-badge stat-badge--up">
                    <i class="bi bi-arrow-up-short"></i> Active
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Middle Row -->
<div class="row g-4 mb-4">
    <!-- Recent Students -->
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-people me-2 text-primary"></i>Recent Students
                </h5>
                <a asp-controller="Student" asp-action="Index" class="btn btn-sm btn-light">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table uni-table mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="https://randomuser.me/api/portraits/women/44.jpg" class="student-avatar" alt="Alice" />
                                    <div>
                                        <div class="fw-semibold">Alice Johnson</div>
                                        <div class="text-muted small">alice.johnson@university.edu</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">+1 (555) 101-2020</td>
                            <td><span class="status-badge status-badge--active">Active</span></td>
                            <td>
                                <a asp-controller="Student" asp-action="Details" asp-route-id="1" class="btn btn-sm btn-icon">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="https://randomuser.me/api/portraits/men/32.jpg" class="student-avatar" alt="Bob" />
                                    <div>
                                        <div class="fw-semibold">Bob Martinez</div>
                                        <div class="text-muted small">bob.martinez@university.edu</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">+1 (555) 303-4040</td>
                            <td><span class="status-badge status-badge--active">Active</span></td>
                            <td>
                                <a asp-controller="Student" asp-action="Details" asp-route-id="2" class="btn btn-sm btn-icon">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="https://randomuser.me/api/portraits/women/68.jpg" class="student-avatar" alt="Clara" />
                                    <div>
                                        <div class="fw-semibold">Clara Smith</div>
                                        <div class="text-muted small">clara.smith@university.edu</div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">+1 (555) 505-6060</td>
                            <td><span class="status-badge status-badge--active">Active</span></td>
                            <td>
                                <a asp-controller="Student" asp-action="Details" asp-route-id="3" class="btn btn-sm btn-icon">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Stats / Activity -->
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-activity me-2 text-primary"></i>Quick Stats
                </h5>
            </div>
            <div class="quick-stats-list">
                <div class="quick-stat-item">
                    <div class="quick-stat-icon bg-blue-soft">
                        <i class="bi bi-person-plus text-primary"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">New Enrollment</div>
                        <div class="text-muted small">Alice Johnson enrolled today</div>
                    </div>
                    <span class="ms-auto text-muted small">Just now</span>
                </div>
                <div class="quick-stat-item">
                    <div class="quick-stat-icon bg-teal-soft">
                        <i class="bi bi-journal-check text-success"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Course Update</div>
                        <div class="text-muted small">Advanced Math updated</div>
                    </div>
                    <span class="ms-auto text-muted small">2h ago</span>
                </div>
                <div class="quick-stat-item">
                    <div class="quick-stat-icon bg-orange-soft">
                        <i class="bi bi-calendar-check text-warning"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Schedule Change</div>
                        <div class="text-muted small">Physics lab rescheduled</div>
                    </div>
                    <span class="ms-auto text-muted small">5h ago</span>
                </div>
                <div class="quick-stat-item">
                    <div class="quick-stat-icon bg-violet-soft">
                        <i class="bi bi-award text-purple"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Achievement</div>
                        <div class="text-muted small">David Lee honor roll</div>
                    </div>
                    <span class="ms-auto text-muted small">1d ago</span>
                </div>
                <div class="quick-stat-item">
                    <div class="quick-stat-icon bg-blue-soft">
                        <i class="bi bi-envelope text-primary"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">New Message</div>
                        <div class="text-muted small">Faculty meeting reminder</div>
                    </div>
                    <span class="ms-auto text-muted small">2d ago</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row -->
<div class="row g-4">
    <div class="col-md-4">
        <div class="content-card text-center py-4">
            <div class="empty-icon mb-3">
                <i class="bi bi-bar-chart-fill text-primary" style="font-size:2.5rem;"></i>
            </div>
            <h6 class="fw-bold">Analytics</h6>
            <p class="text-muted small mb-3">View detailed performance reports and enrollment trends.</p>
            <button class="btn btn-sm btn-outline-primary disabled">Coming Soon</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card text-center py-4">
            <div class="empty-icon mb-3">
                <i class="bi bi-calendar3 text-teal" style="font-size:2.5rem;"></i>
            </div>
            <h6 class="fw-bold">Academic Calendar</h6>
            <p class="text-muted small mb-3">Manage semesters, exams, and holidays in one place.</p>
            <button class="btn btn-sm btn-outline-secondary disabled">Coming Soon</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card text-center py-4">
            <div class="empty-icon mb-3">
                <i class="bi bi-mortarboard text-violet" style="font-size:2.5rem;"></i>
            </div>
            <h6 class="fw-bold">Graduation Tracker</h6>
            <p class="text-muted small mb-3">Track credit hours and graduation requirements.</p>
            <button class="btn btn-sm btn-outline-secondary disabled">Coming Soon</button>
        </div>
    </div>
</div>
