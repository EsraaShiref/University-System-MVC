@model List<University_System.Models.Student>
@{
    ViewData["Title"] = "Dashboard";
    int studentCount    = ViewBag.StudentCount    ?? 0;
    int deptCount       = ViewBag.DeptCount       ?? 0;
    int courseCount     = ViewBag.CourseCount     ?? 0;
    int instructorCount = ViewBag.InstructorCount ?? 0;
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back, Admin! Here's what's happening today.</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-controller="Department" asp-action="Add" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-building me-1"></i> Add Department
        </a>
        <a asp-controller="Student" asp-action="Add" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Student
        </a>
    </div>
</div>

<!-- Stats Cards (real data) -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--blue">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-body">
                <p class="stat-label">Total Students</p>
                <h3 class="stat-value">@studentCount</h3>
                <a asp-controller="Student" asp-action="Index"
                   class="stat-badge stat-badge--up text-decoration-none">
                    <i class="bi bi-arrow-right-short"></i> View all
                </a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--teal">
            <div class="stat-icon"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div class="stat-body">
                <p class="stat-label">Total Courses</p>
                <h3 class="stat-value">@courseCount</h3>
                <span class="stat-badge stat-badge--neutral">
                    <i class="bi bi-dash"></i> This term
                </span>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--violet">
            <div class="stat-icon"><i class="bi bi-building"></i></div>
            <div class="stat-body">
                <p class="stat-label">Departments</p>
                <h3 class="stat-value">@deptCount</h3>
                <a asp-controller="Department" asp-action="Index"
                   class="stat-badge stat-badge--up text-decoration-none">
                    <i class="bi bi-arrow-right-short"></i> View all
                </a>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-card--orange">
            <div class="stat-icon"><i class="bi bi-person-workspace"></i></div>
            <div class="stat-body">
                <p class="stat-label">Instructors</p>
                <h3 class="stat-value">@instructorCount</h3>
                <span class="stat-badge stat-badge--up">
                    <i class="bi bi-check2"></i> Active
                </span>
            </div>
        </div>
    </div>
</div>

<!-- Middle Row -->
<div class="row g-4 mb-4">
    <!-- Recent Students (real from DB) -->
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-people me-2 text-primary"></i>Recent Students
                </h5>
                <a asp-controller="Student" asp-action="Index" class="btn btn-sm btn-light ms-auto">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="table-responsive">
                <table class="table uni-table mb-0">
                    <thead>
                        <tr>
                            <th>Student</th>
                            <th>Department</th>
                            <th>Courses</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var s in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(s.Image))
                                            {
                                                <img src="@Url.Content("~/images/" + s.Image)"
                                                     class="student-avatar" alt="@s.Name" />
                                            }
                                            else
                                            {
                                                <div class="student-avatar-placeholder">
                                                    @(s.Name?.Substring(0, 1).ToUpper())
                                                </div>
                                            }
                                            <div>
                                                <div class="fw-semibold">@s.Name</div>
                                                <div class="text-muted small">@s.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (s.Department != null)
                                        {
                                            <span class="dept-badge">
                                                <i class="bi bi-building me-1"></i>@s.Department.Name
                                            </span>
                                        }
                                        else { <span class="text-muted small">—</span> }
                                    </td>
                                    <td>
                                        @{ var cc = s.StudentCourses?.Count ?? 0; }
                                        @if (cc > 0)
                                        {
                                            <span class="courses-badge">
                                                <i class="bi bi-journal-bookmark me-1"></i>@cc
                                            </span>
                                        }
                                        else { <span class="text-muted small">0</span> }
                                    </td>
                                    <td><span class="status-badge status-badge--active">Active</span></td>
                                    <td>
                                        <a asp-controller="Student" asp-action="Details"
                                           asp-route-id="@s.Id" class="btn btn-sm btn-icon">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No students found.
                                    <a asp-controller="Student" asp-action="Add">Add one?</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-lightning-charge me-2 text-primary"></i>Quick Actions
                </h5>
            </div>
            <div class="p-3 d-flex flex-column gap-2">
                <a asp-controller="Student" asp-action="Add"
                   class="quick-action-btn">
                    <div class="quick-action-icon bg-blue-soft">
                        <i class="bi bi-person-plus-fill text-primary"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Enroll New Student</div>
                        <div class="text-muted small">Add a student to the system</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
                <a asp-controller="Department" asp-action="Add"
                   class="quick-action-btn">
                    <div class="quick-action-icon bg-violet-soft">
                        <i class="bi bi-building-add text-purple"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Add Department</div>
                        <div class="text-muted small">Create a new department</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
                <a asp-controller="Student" asp-action="Index"
                   class="quick-action-btn">
                    <div class="quick-action-icon bg-teal-soft">
                        <i class="bi bi-people-fill text-success"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">View All Students</div>
                        <div class="text-muted small">Browse the full student list</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
                <a asp-controller="Department" asp-action="Index"
                   class="quick-action-btn">
                    <div class="quick-action-icon bg-orange-soft">
                        <i class="bi bi-diagram-3-fill text-warning"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">View Departments</div>
                        <div class="text-muted small">Manage all departments</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>
