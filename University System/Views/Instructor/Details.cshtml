@model University_System.Models.Instructor
@{
    ViewData["Title"] = "Instructor Details";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-subtitle">Instructor Profile & Course Information</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.InstructorId"
               class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back to List
        </a>
    </div>
</div>

<!-- Instructor Information Cards -->
<div class="row g-4 mb-4">
    <!-- Personal Info Card -->
    <div class="col-lg-6">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-person-badge me-2 text-primary"></i>Personal Information
                </h5>
            </div>
            <div class="p-4">
                <div class="info-group">
                    <label class="info-label">Full Name</label>
                    <p class="info-value">@Model.Name</p>
                </div>
                <div class="info-group">
                    <label class="info-label">Email Address</label>
                    <p class="info-value">@Model.Email</p>
                </div>
                <div class="info-group">
                    <label class="info-label">Age</label>
                    <p class="info-value">@Model.Age years</p>
                </div>
                <div class="info-group">
                    <label class="info-label">Address</label>
                    <p class="info-value">@Model.Address</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Academic Info Card -->
    <div class="col-lg-6">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="content-card-title">
                    <i class="bi bi-mortarboard me-2 text-primary"></i>Academic Information
                </h5>
            </div>
            <div class="p-4">
                <div class="info-group">
                    <label class="info-label">Department</label>
                    @if (Model.Department != null)
                    {
                        <p class="info-value">
                            <span class="dept-badge">
                                <i class="bi bi-building me-1"></i>@Model.Department.Name
                            </span>
                        </p>
                    }
                    else
                    {
                        <p class="info-value text-muted">Not assigned</p>
                    }
                </div>
                <div class="info-group">
                    <label class="info-label">Degree</label>
                    <p class="info-value">@Model.Degree</p>
                </div>
                <div class="info-group">
                    <label class="info-label">Salary</label>
                    <p class="info-value">$@Model.Salary.ToString("F2")</p>
                </div>
                <div class="info-group">
                    <label class="info-label">Instructor ID</label>
                    <p class="info-value"><span class="badge bg-light text-dark">#@Model.InstructorId</span></p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Courses Table -->
@if (Model.CourseInstructors != null && Model.CourseInstructors.Any())
{
    <div class="content-card">
        <div class="content-card-header">
            <h5 class="content-card-title">
                <i class="bi bi-journal-bookmark-fill me-2 text-primary"></i>Assigned Courses
            </h5>
            <span class="ms-auto text-muted small">@Model.CourseInstructors.Count course(s)</span>
        </div>
        <div class="table-responsive">
            <table class="table uni-table mb-0">
                <thead>
                    <tr>
                        <th>Course Name</th>
                        <th>Total Degree</th>
                        <th>Min Degree</th>
                        <th>Hours</th>
                        <th>Topics</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var courseInstructor in Model.CourseInstructors)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@courseInstructor.Course?.Name</div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">@courseInstructor.Course?.TotalDegree</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">@courseInstructor.Course?.MinDegree</span>
                            </td>
                            <td>
                                <span class="badge bg-info text-white">@courseInstructor.Hours hrs</span>
                            </td>
                            <td>
                                <span class="text-muted small">
                                    @(courseInstructor.Course?.Topics?.Length > 40 ? courseInstructor.Course.Topics.Substring(0, 40) + "..." : courseInstructor.Course?.Topics)
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="content-card">
        <div class="p-4 text-center text-muted">
            <i class="bi bi-info-circle me-2"></i>
            <span>No courses assigned to this instructor.</span>
        </div>
    </div>
}
